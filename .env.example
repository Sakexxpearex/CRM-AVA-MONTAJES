# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
APP_NAME=Laravel
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-app.up.railway.app
APP_KEY=
VITE_APP_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Database (Postgres)
# NOTE: this app does NOT use Laravel's standard DB_* connection. It defines
# custom "usuarios" / "crm" / "laravel" / "public" connections in
# config/database.php that all point at ONE physical Postgres database via
# PG_* vars, distinguished only by schema (search_path). DB_CONNECTION picks
# which of those four is the default. Migrations create the schemas
# themselves (see database/migrations/0000_00_00_000000_create_schemas.php).
# ---------------------------------------------------------------------------
DB_CONNECTION=laravel
PG_URL=
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=postgres
PG_USERNAME=postgres
PG_PASSWORD=postgres
PG_CHARSET=utf8

# ---------------------------------------------------------------------------
# Redis (cache + sessions)
# ---------------------------------------------------------------------------
REDIS_CLIENT=predis
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ---------------------------------------------------------------------------
# Queue / mail (no queued jobs or scheduled tasks exist yet — kept simple)
# ---------------------------------------------------------------------------
QUEUE_CONNECTION=database
MAIL_MAILER=log

# ---------------------------------------------------------------------------
# Filesystem
# ---------------------------------------------------------------------------
FILESYSTEM_DISK=local

# ---------------------------------------------------------------------------
# Third-party services
# ---------------------------------------------------------------------------
GROQ_API_KEY=

# ---------------------------------------------------------------------------
# Debug tooling — keep OFF in production/demo deployments
# ---------------------------------------------------------------------------
TELESCOPE_ENABLED=false
PULSE_ENABLED=false

# ---------------------------------------------------------------------------
# Container runtime
# ---------------------------------------------------------------------------
# Railway injects PORT automatically; RUN_MIGRATIONS=false skips
# "php artisan migrate --force" on container boot (docker/entrypoint.sh).
PORT=8080
RUN_MIGRATIONS=true
